{
  "name": "tt-calendar",
  "version": "1.2.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "axios": "^1.18.1",
    "ical": "^0.8.0",
    "rrule": "^2.8.1"
  },
  "build": {
    "appId": "com.tt.calendar",
    "productName": "TT-Calendar",
    "icon": "icon.ico",
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
